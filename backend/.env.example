# ─────────────────────────────────────────────
#  MySQL Database Configuration
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=instagram_bot

# ─────────────────────────────────────────────
#  Connection Pool Settings
# ─────────────────────────────────────────────
DB_POOL_SIZE=5
DB_POOL_MAX_OVERFLOW=10

# ─────────────────────────────────────────────
#  App URLs
#  In production replace with your real domain.
#  In local dev use your ngrok HTTPS URL.
# ─────────────────────────────────────────────
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com
INSTAGRAM_REDIRECT_URI=https://your-domain.com/auth/instagram/callback
FACEBOOK_REDIRECT_URI=https://your-domain.com/auth/instagram/callback

# ─────────────────────────────────────────────
#  Instagram / Meta App Credentials
#  Get from: developers.facebook.com > Your App > App Settings > Basic
#  FACEBOOK_APP_SECRET and INSTAGRAM_APP_SECRET must be identical.
# ─────────────────────────────────────────────
FACEBOOK_APP_ID=your_facebook_app_id
INSTAGRAM_APP_ID=your_instagram_app_id
FACEBOOK_APP_SECRET=your_app_secret
INSTAGRAM_APP_SECRET=your_app_secret

# ─────────────────────────────────────────────
#  Webhook
# ─────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=choose_a_random_string

# ─────────────────────────────────────────────
#  Security Keys — generate with:
#  python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=generate_random_string_here
SESSION_SECRET=generate_random_string_here

# ─────────────────────────────────────────────
#  Local Dev Only — remove before production
#  Maps Meta test webhook IDs to real instagram_ids
#  Format: fake_id:real_id
# ─────────────────────────────────────────────
WEBHOOK_TEST_ID_MAP=

# ─────────────────────────────────────────────
#  Optional: Page Access Token (for testing)
# ─────────────────────────────────────────────
PAGE_ACCESS_TOKEN=
